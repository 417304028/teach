# Hermesclaw 课件生成平台配置

# ===== 服务配置 =====
HERMESCLAW_ADDR=:8080
HERMESCLAW_BASE_URL=http://localhost:8080
HERMESCLAW_DATA_DIR=data
HERMESCLAW_STORE=postgres
HERMESCLAW_DATABASE_URL=postgres://hermesclaw:hermesclaw@localhost:5432/hermesclaw?sslmode=disable

# ===== 文件与检索 =====
HERMESCLAW_FILE_TTL=30m
HERMESCLAW_RAG_THRESHOLD=0.60
HERMESCLAW_CHUNK_SIZE=1200
HERMESCLAW_CHUNK_OVERLAP=200
HERMESCLAW_INGEST_CONCURRENCY=4
HERMESCLAW_MAX_JOB_INPUT_TOKENS=32000

# ===== 日志 =====
HERMESCLAW_LOG_LEVEL=info
HERMESCLAW_LOG_JSON=false

# ===== 管理后台 =====
HERMESCLAW_ADMIN_USER=admin
HERMESCLAW_ADMIN_PASSWORD=change-me

# ===== AI - DeepSeek =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== AI - 向量嵌入（阿里云 DashScope） =====
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# ===== QQ Bot (OneBot/NapCat) =====
ONEBOT_HTTP_API=
ONEBOT_ACCESS_TOKEN=
QQ_ALLOWED_IDS=

# ===== 微信 (Clawbot) =====
CLAWBOT_TOKEN=
